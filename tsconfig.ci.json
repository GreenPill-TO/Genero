{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "app/api/**/*.ts",
    "services/**/*.ts",
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "app/tcoin/contracts/**/*.ts",
    "app/tcoin/contracts/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "contracts/foundry/**"
  ]
}
