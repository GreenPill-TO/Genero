# Secrets only. Public chain and protocol addresses live in deploy-config.json.

# Chain selection is public runtime input, not a secret.
# Pass it explicitly when needed, for example:
# DEPLOY_TARGET_CHAIN=celo forge script ...

# RPC endpoints
MAINNET_RPC_URL=
SEPOLIA_RPC_URL=

# Deployment key (do not commit real values)
PRIVATE_KEY=

# Optional block explorer API keys
ETHERSCAN_API_KEY=
CELOSCAN_API_KEY=
