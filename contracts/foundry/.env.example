# Secrets only. Public chain and protocol values live in deploy-config.json.

# Celo mainnet RPC endpoint
CELO_MAINNET_RPC_URL=

# Deployment key (do not commit real values)
PRIVATE_KEY=

# Optional scenario-B execution key if you do not want to reuse PRIVATE_KEY
SCENARIO_B_PRIVATE_KEY=

# Optional block explorer API key
CELOSCAN_API_KEY=
