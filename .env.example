# Genero Next app environment template
# Copy this file to `.env.local` for local development.
# Optional local-only Supabase target profiles can live in
# `.env.local-supabase-local` and `.env.local-supabase-remote`.
# Keep shared local values in `.env.local`, and put only the scenario-specific
# Supabase target vars in those ignored profile files.
# Supabase Edge Functions have their own companion template at
# `supabase/functions/.env.example`.
# For staging and production, mirror the relevant keys in your deployment platform.
# Variables prefixed with `NEXT_PUBLIC_` are exposed to the browser.
# Never commit real secrets to version control.

# ------------------------------------------------------------------------------
# Supabase core
# ------------------------------------------------------------------------------

# Base Supabase project URL used by browser, server, and middleware clients.
# Example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>

# Supabase publishable key for browser and request-scoped server usage.
# Example: eyJhbGciOi...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>

# Server-only service-role key for privileged API and release-ops reads.
# Example: eyJhbGciOi... (service_role key from Supabase project settings)
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Optional extra public image origins, comma-separated, for remote image loading & whitelisting. Does not yet display anywhere in the UI but is read by the image asset management and loading logic.
# Example: https://foo.supabase.co/storage/v1/object/public/assets/a.png,https://bar.supabase.co/storage/v1/object/public/assets/b.png
NEXT_PUBLIC_SUPABASE_IMAGE_URLS=<optional-comma-separated-image-asset-urls>

# ------------------------------------------------------------------------------
# App runtime and public URLs
# ------------------------------------------------------------------------------

# Active city slug.
# Example: tcoin
NEXT_PUBLIC_CITYCOIN=tcoin

# Active app slug.
# Example: wallet | sparechange | contracts
NEXT_PUBLIC_APP_NAME=wallet

# Runtime environment for auth/bootstrap behaviour.
# Example: local | development | staging | production
# Local and development are functionally equivalent, bypasses auth
# Staging enforces auth but enables delete
# Production is the most locked down, with no auth bypasses and no delete
NEXT_PUBLIC_APP_ENVIRONMENT=local

# Fallback CAD estimate used only when the city exchange-rate service returns
# `empty` or `setup_required`.
# Example: 3.35
NEXT_PUBLIC_CITYCOIN_CAD_FALLBACK_RATE=3.35

# Public wallet base URL used for shareable Receive and pay-link generation.
# Example: https://www.tcoin.me
NEXT_PUBLIC_WALLET_PUBLIC_BASE_URL=https://www.tcoin.me

# Canonical site URL used by public callbacks and CORS fallbacks.
# Example: https://www.tcoin.me
NEXT_PUBLIC_SITE_URL=https://www.tcoin.me

# Explorer base URL used for address links in wallet surfaces.
# Include the trailing path segment if your explorer expects one.
# Example: https://celoscan.io/address/
NEXT_PUBLIC_EXPLORER_URL=https://celoscan.io/address/

# Comma-separated frontend origins allowed to call authenticated edge functions.
# Include every deployed wallet or sparechange origin plus any local hosts used
# during development.
# Example: http://localhost:3000,http://127.0.0.1:3000,https://wallet.example.com
USER_SETTINGS_ALLOWED_ORIGINS=<comma-separated-frontend-origins>

# Optional local or development auth bypass user id.
# Do not set this in staging or production, and there is no implicit fallback:
# if you want bypass mode locally, this must point to a real `public.users.id`.
# Example: 1
AUTH_BYPASS_USER_ID=<optional-user-id-for-local-auth-bypass>

# ------------------------------------------------------------------------------
# Wallet public assets
# ------------------------------------------------------------------------------

# Public light-mode TorontoCoin banner image.
# Example: https://your-project-ref.supabase.co/storage/v1/object/public/website-images/tcoin-banner-light-mode.png
NEXT_PUBLIC_TCOIN_BANNER_LIGHT_URL=<supabase-public-url-to-light-banner-image>

# Public dark-mode TorontoCoin banner image.
# Example: https://your-project-ref.supabase.co/storage/v1/object/public/website-images/tcoin-banner-dark-mode.png
NEXT_PUBLIC_TCOIN_BANNER_DARK_URL=<supabase-public-url-to-dark-banner-image>

# Public onboarding or welcome video asset.
# Example: https://your-project-ref.supabase.co/storage/v1/object/public/screen_recording/welcome-video.mov
NEXT_PUBLIC_TCOIN_WELCOME_VIDEO_URL=<supabase-public-url-to-welcome-video>

# ------------------------------------------------------------------------------
# Cubid onboarding
# ------------------------------------------------------------------------------

# Cubid public API key used by onboarding widgets.
# Example: cdk_live_abc123...
NEXT_PUBLIC_CUBID_API_KEY=<your-cubid-api-key>

# Cubid app id used by onboarding widgets.
# Example: app_1234567890
NEXT_PUBLIC_CUBID_APP_ID=<your-cubid-app-id>

# ------------------------------------------------------------------------------
# Merchant signup and verification services
# ------------------------------------------------------------------------------

# Feature flag for merchant signup and city-manager approval surfaces.
# Example: true | false
NEXT_PUBLIC_ENABLE_MERCHANT_SIGNUP=false

# Explicit User-Agent for Nominatim geocoding requests.
# Production should set this when merchant signup is enabled.
# Example: Genero Merchant Signup Geocoder
NOMINATIM_USER_AGENT=<optional-nominatim-user-agent>

# ------------------------------------------------------------------------------
# Phone verification / OTP infrastructure
# ------------------------------------------------------------------------------

# Twilio account sid for OTP and off-ramp verification.
# Example: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=<twilio-account-sid>

# Twilio auth token for OTP and off-ramp verification.
# Example: your-twilio-auth-token
TWILIO_AUTH_TOKEN=<twilio-auth-token>

# Twilio Verify service sid for OTP and off-ramp verification.
# Example: VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=<twilio-verify-service-sid>

# ------------------------------------------------------------------------------
# Contracts management
# ------------------------------------------------------------------------------

# Feature flag for enabling write-capable contract-management actions in the UI.
# Keep this `false` unless write flows are intentionally enabled for the target env.
# Example: true | false
NEXT_PUBLIC_ENABLE_CONTRACT_MGMT_WRITES=false

# ------------------------------------------------------------------------------
# Indexer runtime
# ------------------------------------------------------------------------------

# Chain id for the wallet indexer and TorontoCoin ops reads.
# Example: 42220 (Celo mainnet), 44787 (Celo Alfajores)
INDEXER_CHAIN_ID=42220

# RPC URL for indexer reads.
# Example: https://forno.celo.org
INDEXER_CHAIN_RPC_URL=https://forno.celo.org

# Full-history backfill start block for the configured chain and scope.
# Example: 0
INDEXER_INITIAL_BLOCK=0

# Maximum number of blocks processed in one indexer run.
# Example: 2000
INDEXER_MAX_BLOCKS_PER_RUN=2000

# Maximum number of Sarafu pool-index entries scanned during discovery.
# Example: 500
INDEXER_DISCOVERY_POOL_LIMIT=500

# Optional tracker bridge endpoint for tracker-pull ingestion.
# Leave empty unless that bridge is intentionally deployed.
# Example: http://localhost:8787/tracker/pull
INDEXER_TRACKER_PULL_URL=<optional-http-endpoint-for-tracker-pulls>

# ------------------------------------------------------------------------------
# Buy TCOIN checkout orchestrator
# ------------------------------------------------------------------------------

# Feature flag for the Buy TCOIN checkout UI and API surface.
# Keep this `false` unless the full Transak plus auto-mint path is validated.
# Example: true | false
NEXT_PUBLIC_ENABLE_BUY_TCOIN_CHECKOUT=false

# Checkout provider identifier.
# Example: transak
ONRAMP_PROVIDER=transak

# Shared secret used by the Next.js webhook ingress when forwarding verified
# Transak events to the Supabase onramp edge function.
# Example: generate-a-long-random-shared-secret
ONRAMP_WEBHOOK_FORWARD_SECRET=<shared-secret-for-forwarding-verified-transak-webhooks>

# Transak partner API key included in widget parameters.
# Example: 12345678-90ab-cdef-1234-567890abcdef
ONRAMP_TRANSAK_API_KEY=<transak-api-key>

# Transak server secret used for partner-side auth or refresh workflows.
# Example: your-transak-secret
ONRAMP_TRANSAK_SECRET=<transak-secret>

# Optional legacy webhook signature secret.
# Leave empty when using the access-token or JWT verification flow instead.
# Example: your-legacy-webhook-secret
ONRAMP_TRANSAK_WEBHOOK_SECRET=<optional-legacy-transak-webhook-secret>

# Secure Widget URL endpoint for the Transak backend API.
# Staging example: https://api-gateway-stg.transak.com/api/v2/auth/session
# Production example: https://api-gateway.transak.com/api/v2/auth/session
ONRAMP_TRANSAK_WIDGET_API_URL=https://api-gateway-stg.transak.com/api/v2/auth/session

# Access token required by the Transak Create Widget URL API.
# Example: your-transak-access-token
ONRAMP_TRANSAK_ACCESS_TOKEN=<transak-access-token>

# Optional user-auth token for user-authenticated Transak widget sessions.
# Leave empty unless your integration requires it.
# Example: your-transak-user-auth-token
ONRAMP_TRANSAK_USER_AUTH_TOKEN=<optional-transak-user-auth-token>

# Base URL used in provider redirect metadata.
# Example: http://localhost:3000
ONRAMP_APP_BASE_URL=http://localhost:3000

# Target chain id for settlement and mint execution.
# Example: 42220
ONRAMP_TARGET_CHAIN_ID=42220

# Checkout input asset label.
# Example: USDC
ONRAMP_TARGET_INPUT_ASSET=USDC

# Final asset label produced by the flow.
# Example: TCOIN
ONRAMP_FINAL_ASSET=TCOIN

# Settlement timeout in seconds.
# Example: 600
ONRAMP_SETTLEMENT_TIMEOUT_SECONDS=600

# Maximum automatic settlement attempts.
# Example: 3
ONRAMP_MAX_AUTO_ATTEMPTS=3

# Maximum manual settlement attempts.
# Example: 3
ONRAMP_MAX_MANUAL_ATTEMPTS=3

# Slippage guard in basis points.
# Example: 100
ONRAMP_SLIPPAGE_BPS=100

# Execution deadline in seconds.
# Example: 900
ONRAMP_DEADLINE_SECONDS=900

# Master seed used to derive deterministic per-user deposit wallets.
# Use either a mnemonic phrase or a raw hex seed.
# Example: urge clog right ...
# Example: 0xabc123...
ONRAMP_HD_MASTER_SEED=<mnemonic-or-hex-seed>

# Base derivation path; the user id is appended as the final segment.
# Example: m/44'/52752'/0'/0
ONRAMP_HD_DERIVATION_PATH_BASE=m/44'/52752'/0'/0

# Server gas-bank private key for JIT CELO top-ups to deposit wallets.
# Must be a 32-byte hex private key.
# Example: 0x0123456789abcdef...
ONRAMP_GAS_BANK_PRIVATE_KEY=<0x-64-hex-private-key>

# Minimum CELO balance threshold before a top-up is triggered.
# Example: 1000000000000000
ONRAMP_GAS_TOPUP_MIN_WEI=1000000000000000

# Target CELO balance after a top-up.
# Example: 5000000000000000
ONRAMP_GAS_TOPUP_TARGET_WEI=5000000000000000

# ------------------------------------------------------------------------------
# TorontoCoin operator-script controls
# ------------------------------------------------------------------------------

# Optional comma-separated list of pool ids for bounded acceptance previews or buys.
# Leave empty to use the runtime defaults.
# Example: 0xabc...,0xdef...
TORONTOCOIN_ACCEPTANCE_POOL_IDS=<optional-comma-separated-pool-ids>

# Set to `true` only when intentionally executing a live acceptance buy.
# Keep `false` for normal previews and release checks.
# Example: true | false
TORONTOCOIN_LIVE_BUY_ENABLED=false

# Deployer or operator key used by Foundry deploy scripts and by live TorontoCoin
# acceptance buys when `TORONTOCOIN_LIVE_BUY_ENABLED=true`.
# Leave empty for normal preview-only checks.
# Example: 0x0123456789abcdef...
DEPLOYER_KEY=<optional-deployer-or-live-acceptance-key>
