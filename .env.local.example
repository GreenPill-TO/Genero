# Genero local environment template
# Copy this file to `.env.local` and replace values.
# Note: variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ------------------------------------------------------------------------------
# Supabase core config
# ------------------------------------------------------------------------------

# Example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>

# Example: eyJhbGciOi... (Supabase publishable key for web client usage)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<your-supabase-publishable-default-key>

# Server-only key used by API routes for privileged writes (indexer run control/event persistence).
# Example: eyJhbGciOi... (service_role key from Supabase project settings)
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Optional extra image sources (comma-separated URLs).
# Example: https://foo.supabase.co/storage/v1/object/public/assets/a.png,https://bar.supabase.co/storage/v1/object/public/assets/b.png
NEXT_PUBLIC_SUPABASE_IMAGE_URLS=<optional-comma-separated-image-asset-urls>

# ------------------------------------------------------------------------------
# Cubid config
# ------------------------------------------------------------------------------

# Example: cdk_live_abc123...
NEXT_PUBLIC_CUBID_API_KEY=<your-cubid-api-key>

# Example: app_1234567890
NEXT_PUBLIC_CUBID_APP_ID=<your-cubid-app-id>

# ------------------------------------------------------------------------------
# TCOIN wallet static asset URLs (public Supabase storage links)
# ------------------------------------------------------------------------------

# Example: https://your-project-ref.supabase.co/storage/v1/object/public/website-images/tcoin-banner-light-mode.png
NEXT_PUBLIC_TCOIN_BANNER_LIGHT_URL=<supabase-public-url-to-light-banner-image>

# Example: https://your-project-ref.supabase.co/storage/v1/object/public/website-images/tcoin-banner-dark-mode.png
NEXT_PUBLIC_TCOIN_BANNER_DARK_URL=<supabase-public-url-to-dark-banner-image>

# Example: https://your-project-ref.supabase.co/storage/v1/object/public/screen_recording/welcome-video.mov
NEXT_PUBLIC_TCOIN_WELCOME_VIDEO_URL=<supabase-public-url-to-welcome-video>

# ------------------------------------------------------------------------------
# App selection / runtime mode
# ------------------------------------------------------------------------------

# Example: tcoin
NEXT_PUBLIC_CITYCOIN=<city>

# Example: wallet | sparechange | contracts
NEXT_PUBLIC_APP_NAME=<app-name>

# Example: local | development | staging | production
NEXT_PUBLIC_APP_ENVIRONMENT=<environment>

# ------------------------------------------------------------------------------
# Indexer config (defaults target Celo mainnet)
# ------------------------------------------------------------------------------

# Example: 42220 (Celo mainnet), 44787 (Celo Alfajores)
INDEXER_CHAIN_ID=42220

# Example: https://forno.celo.org
INDEXER_CHAIN_RPC_URL=https://forno.celo.org

# Full-history backfill start block for the configured chain/scope.
# Example: 0
INDEXER_INITIAL_BLOCK=0

# Per-trigger max blocks processed in one run.
# Example: 2000
INDEXER_MAX_BLOCKS_PER_RUN=2000

# Max Sarafu pool-index entries to scan during discovery.
# Example: 500
INDEXER_DISCOVERY_POOL_LIMIT=500

# Optional tracker pull bridge endpoint (HTTP).
# Example: http://localhost:8787/tracker/pull
INDEXER_TRACKER_PULL_URL=<optional-http-endpoint-for-tracker-pulls>

# ------------------------------------------------------------------------------
# Buy TCOIN checkout orchestrator (Transak + managed deposit + auto-mint)
# ------------------------------------------------------------------------------

# Feature flag for the new Buy TCOIN checkout UI/API surface.
# Example: true
NEXT_PUBLIC_BUY_TCOIN_CHECKOUT_V1=false

# Provider selection (v1 supports transak only).
ONRAMP_PROVIDER=transak

# Transak partner API key used in generated widget config.
# Example: 12345678-90ab-cdef-1234-567890abcdef
ONRAMP_TRANSAK_API_KEY=<transak-api-key>

# Transak server secret (reserved for future secure server-side session signing).
ONRAMP_TRANSAK_SECRET=<transak-secret>

# Transak webhook signature secret used to verify inbound events.
ONRAMP_TRANSAK_WEBHOOK_SECRET=<transak-webhook-secret>

# Base URL used for redirect metadata from provider checkout.
# Example: http://localhost:3000
ONRAMP_APP_BASE_URL=http://localhost:3000

# Target chain for USDC settlement and router mint execution.
# Example: 42220
ONRAMP_TARGET_CHAIN_ID=42220

# Input and output asset labels for checkout metadata.
ONRAMP_TARGET_INPUT_ASSET=USDC
ONRAMP_FINAL_ASSET=TCOIN

# Settlement retry/timeout controls.
ONRAMP_SETTLEMENT_TIMEOUT_SECONDS=600
ONRAMP_MAX_AUTO_ATTEMPTS=3
ONRAMP_MAX_MANUAL_ATTEMPTS=3

# Mint guard controls: 100 bps = 1.0% slippage, deadline in seconds.
ONRAMP_SLIPPAGE_BPS=100
ONRAMP_DEADLINE_SECONDS=900

# HD master seed used to derive deterministic per-user deposit wallets.
# Use either a mnemonic phrase or a raw hex seed.
# Example (mnemonic): urge clog right ...
# Example (hex): 0xabc123...
ONRAMP_HD_MASTER_SEED=<mnemonic-or-hex-seed>

# Base derivation path; user id is appended as final path segment.
# Example: m/44'/52752'/0'/0
ONRAMP_HD_DERIVATION_PATH_BASE=m/44'/52752'/0'/0

# Server gas-bank private key for JIT CELO topups to deposit wallets.
# Must be a 32-byte hex private key.
ONRAMP_GAS_BANK_PRIVATE_KEY=<0x-64-hex-private-key>

# JIT topup thresholds (wei) for deposit wallets.
# Example: 1000000000000000  (0.001 CELO)
# Example: 5000000000000000  (0.005 CELO target)
ONRAMP_GAS_TOPUP_MIN_WEI=1000000000000000
ONRAMP_GAS_TOPUP_TARGET_WEI=5000000000000000

# On-chain contract addresses for settlement runner.
# Example USDC (Celo): 0x765DE816845861e75A25fCA122bb6898B8B1282a
ONRAMP_USDC_TOKEN_ADDRESS=<celo-usdc-address>
ONRAMP_ROUTER_ADDRESS=<deployed-tcoin-mint-router-address>

# Adapter policy label + static swapData bytes for router calls.
ONRAMP_SWAP_ADAPTER_ID=default
ONRAMP_SWAP_DATA_HEX=0x
